# Psynote Alpha —— docker-compose 使用的环境变量
#
# 复制为 .env(**不要提交到 git**)并填值。
# 所有标了 REQUIRED 的必须填,否则 compose 启动会失败。
#
# 生成强密钥(在 Linux/WSL/Mac 上):
#   JWT_SECRET:   openssl rand -hex 48
#   POSTGRES_PASSWORD: openssl rand -hex 16

# ─── Domain & URLs (REQUIRED) ────────────────────────────────────
# Caddy 将为此域名自动申请 HTTPS 证书,DNS 必须已指向这台 VPS
CADDY_DOMAIN=app.psynote.example
# CORS 允许源 + 密码重置邮件里的链接基址
CLIENT_URL=https://app.psynote.example
PUBLIC_BASE_URL=https://app.psynote.example

# ─── Postgres (REQUIRED) ─────────────────────────────────────────
POSTGRES_USER=psynote
POSTGRES_PASSWORD=CHANGE_ME_USE_openssl_rand_hex_16
POSTGRES_DB=psynote

# ─── JWT (REQUIRED) ──────────────────────────────────────────────
# ⚠️  生产环境必须用强随机值。本地开发别用 dev 默认值(server env.ts 会拒启动)
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_48

# ─── SMTP (REQUIRED,密码重置邮件必需) ───────────────────────────
# 推荐:阿里云邮件推送 / 腾讯企业邮 / SendGrid
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@psynote.example
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@psynote.example

# ─── AI Provider (OPTIONAL,不填时 AI 相关功能降级) ──────────────
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o
